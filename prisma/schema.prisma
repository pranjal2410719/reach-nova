generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  INFLUENCER
  BRAND
  ADMIN
}

enum CampaignStatus {
  OPEN
  CLOSED
  UPCOMING
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(INFLUENCER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns    Campaign[]
  applications Application[]

  @@index([email])
}

model Campaign {
  id          String         @id @default(cuid())
  title       String
  organization String
  category    String
  status      CampaignStatus @default(OPEN)
  location    String
  deadline    DateTime
  description String
  budget      Decimal?       @db.Decimal(10, 2)
  eligibility String[]      @default([])
  contactInfo String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id], onDelete: Cascade)

  applications Application[]

  @@index([status])
  @@index([category])
  @@index([createdById])
  @@index([deadline])
}

model Application {
  id         String            @id @default(cuid())
  status     ApplicationStatus @default(PENDING)
  message    String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([userId])
  @@index([campaignId])
  @@index([status])
}